# Frontend: Vite exposes only variables that start with VITE_ to browser code.
VITE_WS_URL=ws://127.0.0.1:8000/ws
VITE_DEFAULT_PLAYER_NAME=Player
VITE_BACKEND_ACCESS_TOKEN=change-me-local-dev-token
VITE_DEV_HOST=0.0.0.0
VITE_DEV_PORT=46758
VITE_PREVIEW_HOST=0.0.0.0
VITE_PREVIEW_PORT=4173
VITE_ALLOWED_HOSTS=rtxa.duckdns.org

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_RELOAD=true
BACKEND_LOG_LEVEL=info
BACKEND_LOG_DIR=logs
BACKEND_CORS_ORIGINS=*
BACKEND_CORS_ALLOW_CREDENTIALS=false
BACKEND_APP_TITLE=Neon Aim Arena Backend
BACKEND_APP_VERSION=0.1.0
BACKEND_ACCESS_TOKEN=change-me-local-dev-token

# Production examples:
# VITE_WS_URL=wss://your-backend-domain.com/ws
# VITE_BACKEND_ACCESS_TOKEN=replace-with-the-same-production-token
# BACKEND_CORS_ORIGINS=https://your-frontend-domain.com
# BACKEND_ACCESS_TOKEN=replace-with-the-same-production-token
